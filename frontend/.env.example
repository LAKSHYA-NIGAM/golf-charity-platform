# ─────────────────────────────────────────────────────────
#  GreenHeart Frontend — Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── API ──────────────────────────────────────────────────
# In dev, Vite proxies /api → localhost:5000 (see vite.config.js)
# In production, set this to your deployed backend URL:
VITE_API_URL=/api

# ── Supabase (optional — only if using Supabase client-side) ──
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (public key — safe to expose) ─────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
