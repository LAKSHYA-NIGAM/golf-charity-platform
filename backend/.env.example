# ─────────────────────────────────────────────────────────
#  GreenHeart Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-chars

# ── Supabase ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# (Service role key bypasses RLS — keep it server-side only)

# ── Stripe ───────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
# Create prices in Stripe Dashboard → Products, then paste IDs below:
STRIPE_PRICE_MONTHLY=price_placeholder_monthly
STRIPE_PRICE_YEARLY=price_placeholder_yearly

# ── Resend (Email) ───────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_placeholder
# Must be a verified domain in your Resend account:
EMAIL_FROM=GreenHeart <noreply@yourdomain.com>
